generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  unit      String   @default("kg")
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  message   String
  createdAt DateTime @default(now())
}
